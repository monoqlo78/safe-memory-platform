QWEN_API_KEY=replace_me
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
# Per-request timeout (seconds) and retry cap for Qwen calls. Keep these low so
# a slow/stalled Qwen endpoint falls back to local behaviour instead of making
# large imports appear to hang. Defaults: 30s timeout, 1 retry.
QWEN_TIMEOUT_SECONDS=30
QWEN_MAX_RETRIES=1
SAFE_MEMORY_ROOT=/app/SafeMemory
SAFE_MEMORY_API_KEY=change_me
APP_ENV=production
SAFE_MEMORY_CORS_ORIGINS=http://localhost:3000,http://localhost:8787
SAFE_MEMORY_TEMP_TTL_MINUTES=60
SAFE_MEMORY_TRANSLATION_BATCH_SIZE=20
# Max tokens for query answer generation (lower = faster GPT/Claude responses).
SAFE_MEMORY_ANSWER_MAX_TOKENS=400
# Large-file staging upload channel (LLM-safe direct upload).
SAFE_MEMORY_MAX_UPLOAD_MB=50
SAFE_MEMORY_UPLOAD_TTL_MINUTES=60
# Storage backend for staged uploads: "local" (default) or future "oss".
SAFE_MEMORY_STORAGE_BACKEND=local
# Public HTTPS base URL advertised in openapi.json `servers` for GPT Actions,
# e.g. https://xxxx.trycloudflare.com . Leave empty to omit the servers field.
SAFE_MEMORY_PUBLIC_BASE_URL=
# Pack exchange (import a pack from a URL). Max download size and whether an
# invalid ledger hash chain rejects the import (false = import with a warning).
SAFE_MEMORY_MAX_IMPORT_MB=25
SAFE_MEMORY_IMPORT_REQUIRE_VALID_LEDGER=false
# Timeout (seconds) for server-side URL fetches (buildPackFromUrl / importPackByRef).
SAFE_MEMORY_URL_FETCH_TIMEOUT_SECONDS=30

# ---- Ingestion limits (single file + folder bundles) ----
SAFE_MEMORY_MAX_UPLOAD_FILE_SIZE_MB=50
SAFE_MEMORY_MAX_FOLDER_FILES=200
SAFE_MEMORY_MAX_FOLDER_TOTAL_SIZE_MB=200
SAFE_MEMORY_ALLOWED_EXTENSIONS=.txt,.md,.csv,.xlsx,.xls,.json,.pdf,.docx

# ---- Alibaba Cloud OSS handoff (private bucket; share via signed URLs only) ----
# Leave secrets EMPTY here and set the real values in the server .env only.
# Never commit real AccessKeys. Never use the root account AccessKey.
OSS_ENABLED=false
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
OSS_BUCKET_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_UPLOAD_PREFIX=uploads/
OSS_EXPORT_PREFIX=exports/
OSS_SIGNED_URL_TTL_SECONDS=3600
OSS_DELETE_SOURCE_AFTER_PROCESSING=true
